{
  "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/wp-env.json",
  "core": null,
  "phpVersion": "8.4",
  "config": {
    "WP_DEBUG_DISPLAY": false,
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": "/var/www/html/wp-content/logs/debug.log",
    "SCRIPT_DEBUG": true,
    "WP_ENV": "development"
  },
  "mappings": {
    "wp-content/logs": "./logs"
  },
  "plugins": [
    ".",
    "../premium-plugins/js_composer",
    "https://downloads.wordpress.org/plugin/elementor.latest-stable.zip"
  ],
  "themes": [
    "../premium-themes/flatsome",
    "../premium-themes/Divi",
    "../premium-themes/bricks"
  ],
  "testsEnvironment": false,
  "lifecycleScripts": {
    "afterStart": "bash ./setup.sh"
  }
}
