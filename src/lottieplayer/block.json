{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "gb/lottieplayer",
	"title": "AM LottiePlayer",
	"description": "Play Lottie animations on your WordPress website.",
	"keywords": [
		"animation",
		"gif",
		"motion",
		"vector",
		"SVG",
		"Lottie",
		"dotLottie"
	],
	"category": "media",
	"supports": {
		"align": true,
		"ariaLabel": true,
		"anchor": true,
		"html": false,
		"shadow": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "am-lottieplayer",
	"attributes": {
		"align": {
			"enum": [
				"center",
				"full",
				"none",
				"left",
				"right",
				"wide"
			],
			"default": "none"
		},
		"autoplay": {
			"type": "boolean"
		},
		"background": {
			"type": "string",
			"default": "transparent"
		},
		"controls": {
			"type": "boolean",
			"default": true
		},
		"count": {
			"type": "number",
			"default": null
		},
		"delay": {
			"type": "number",
			"default": null
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"direction": {
			"type": "number",
			"default": 1
		},
		"height": {
			"type": "number",
			"default": null
		},
		"hover": {
			"type": "boolean",
			"default": false
		},
		"id": {
			"type": "string"
		},
		"intermission": {
			"type": "number"
		},
		"loop": {
			"type": "boolean"
		},
		"mode": {
			"enum": [
				"bounce",
				"normal"
			],
			"default": "normal"
		},
		"mouseout": {
			"enum": [
				"void",
				"stop",
				"pause",
				"reverse"
			],
			"default": "stop"
		},
		"objectFit": {
			"type": "string",
			"default": "contain"
		},
		"once": {
			"type": "boolean",
			"default": false
		},
		"playOnClick": {
			"type": "boolean",
			"default": false
		},
		"playOnVisible": {
			"type": "boolean",
			"default": false
		},
		"renderer": {
			"enum": [
				"svg",
				"canvas",
				"html"
			],
			"default": "svg"
		},
		"segment": {
			"type": "array",
			"default": null
		},
		"selector": {
			"type": "string",
			"default": null
		},
		"speed": {
			"type": "number",
			"default": 1
		},
		"src": {
			"type": "string",
			"default": ""
		},
		"subframe": {
			"type": "boolean",
			"default": true
		},
		"width": {
			"type": "number",
			"default": null
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}